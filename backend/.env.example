# =====================================
# TRUTHSCAN — Configuración del Backend
# =====================================

# Puerto del servidor
PORT=8000

# Entorno
ENVIRONMENT=development

# URL del frontend (CORS)
FRONTEND_URL=http://localhost:5173
# En producción: FRONTEND_URL=https://verifai.app

# Hugging Face API Token
# Créalo en: huggingface.co → Settings → Access Tokens → New token (Read)
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Directorios temporales
UPLOAD_DIR=/tmp/verifai/uploads
OUTPUT_DIR=/tmp/verifai/outputs

# Tiempo de expiración de archivos (minutos)
FILE_EXPIRY_MINUTES=30

# Tamaño máximo de archivo (MB)
MAX_FILE_SIZE_MB=200

# Clave secreta
SECRET_KEY=cambia_esto_por_una_clave_secreta_larga
